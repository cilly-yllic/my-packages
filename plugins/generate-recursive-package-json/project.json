{
  "name": "@my-packages/generate-recursive-package-json",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "plugins/generate-recursive-package-json/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "plugins/generate-recursive-package-json/dist",
        "main": "plugins/generate-recursive-package-json/src/index.ts",
        "tsConfig": "plugins/generate-recursive-package-json/tsconfig.lib.json",
        "rootDir": "plugins/generate-recursive-package-json/src",
        "generatePackageJson": false,
        "assets": [
          {
            "input": "./plugins/generate-recursive-package-json/src",
            "glob": "**/!(*.ts)",
            "output": "."
          },
          {
            "input": "./plugins/generate-recursive-package-json/src",
            "glob": "**/*.d.ts",
            "output": "."
          }
        ]
      }
    }
  }
}
